const Shell = () => {
  const { user, page } = useApp();
  const { isDesktop } = useBreakpoint();
  if (!user) return <AuthPage />;

  const isAdmin = user.role !== "client";
  const tabs    = isAdmin ? ADMIN_NAV : CLIENT_NAV;

  if (isAdmin && isDesktop) {
    return (
      <div className="desktop-shell">
        <BgCanvas />
        <Sidebar />
        <div className="desktop-main">
          <div className="desktop-topbar">
            <h2 className="text-xl font-extrabold text-slate-800 tracking-tight">{PAGE_TITLES[page]}</h2>
            <div className="flex items-center gap-3">
              <div className="flex items-center gap-2 bg-white/70 border border-white/80 rounded-full px-4 py-2 shadow-sm">
                <div className="w-2 h-2 rounded-full bg-jade-500 shadow-jade-dot" />
                <span className="text-xs font-semibold text-slate-600">{user.email}</span>
              </div>
            </div>
          </div>
          <div className="desktop-content">
            <AnimatePresence mode="wait">
              <motion.div key={page} {...anim.page}>{PAGES[page]}</motion.div>
            </AnimatePresence>
          </div>
        </div>
      </div>
    );
  }

  return (
    <div className="mobile-shell">
      <BgCanvas />
      <Topbar title={PAGE_TITLES[page]} />
      <div className="mobile-content">
        <AnimatePresence mode="wait">
          <motion.div key={page} {...anim.page}>{PAGES[page]}</motion.div>
        </AnimatePresence>
      </div>
      <BottomNav tabs={tabs} />
    </div>
  );
};

