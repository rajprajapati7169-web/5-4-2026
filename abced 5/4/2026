              <div className="grid grid-cols-2 gap-3">
                {[
                  { val: waiting.length,   label: "Waiting",   color: "text-jade-600",  bg: "bg-jade-50" },
                  { val: completed.length, label: "Served",    color: "text-slate-600", bg: "bg-slate-50" },
                ].map(s => (
                  <div key={s.label} className={`${s.bg} rounded-xl p-3 text-center border border-white/60`}>
