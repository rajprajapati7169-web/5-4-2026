                    <div className="flex-1 min-w-0">
                      <div className="text-sm font-semibold text-slate-700 truncate">{c.name}</div>
                      <div className="text-xs text-slate-400 font-mono">{c.token}</div>
                    </div>
                    <Badge color="jade" dot>Served</Badge>
                  </motion.div>
                ))}
