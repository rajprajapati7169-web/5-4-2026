// § PAGE: CLIENT FORM
// ═══════════════════════════════════════════════════════════
const ClientForm = () => {
  const { fields, nav } = useApp();
  const [vals,  setVals]  = useState({});
  const [toasts, showToast] = useToast();

  const displayFields = fields.length > 0 ? fields : [
    { id: "df1", type: "input",    title: "Full Name",        placeholder: "Enter your full name" },
    { id: "df2", type: "menu",     title: "Purpose of Visit", options: ["Consultation", "Follow-up", "Emergency", "Routine checkup"] },
    { id: "df3", type: "checkbox", title: "Preferred Time",   options: ["Morning (9–12)", "Afternoon (12–4)", "Evening (4–7)"] },
  ];

  const handleSubmit = () => {
    showToast("Token confirmed! Joining queue…", "success");
    setTimeout(() => nav("client-dash"), 1600);
  };

  return (
    <motion.div {...anim.page}>
      <ToastStack toasts={toasts} />
      <h1 className="text-2xl font-black text-slate-800 tracking-tight mb-1">Join the Queue</h1>
      <p className="text-sm text-slate-500 mb-5">Fill once. Relax while you wait.</p>

      <Card className="p-5 mb-3">
        <motion.div variants={anim.stagger} initial="initial" animate="animate">
          {displayFields.map(f => (
            <motion.div key={f.id} variants={anim.fadeUp} className="mb-5 last:mb-0">
              <label className="block text-xs font-extrabold text-slate-500 uppercase tracking-widest mb-2">{f.title}</label>
              {f.type === "input" && (
                <Input placeholder={f.placeholder || ""} value={vals[f.id] || ""} onChange={e => setVals({ ...vals, [f.id]: e.target.value })} />
              )}
              {f.type === "menu" && (
                <Select value={vals[f.id] || ""} onChange={e => setVals({ ...vals, [f.id]: e.target.value })}>
                  <option value="">Select an option</option>
                  {f.options?.map(o => <option key={o}>{o}</option>)}
                </Select>
              )}
              {f.type === "checkbox" && (
                <div className="space-y-2">
                  {f.options?.map(o => {
                    const checked = !!vals[`${f.id}-${o}`];
                    return (
                      <motion.div
                        key={o}
                        onClick={() => setVals({ ...vals, [`${f.id}-${o}`]: !checked })}
                        animate={{ borderColor: checked ? "rgba(28,122,28,0.35)" : "rgba(255,255,255,0.8)" }}
                        whileTap={{ scale: 0.98 }}
                        className="flex items-center gap-3 p-3.5 bg-white/60 rounded-xl border cursor-pointer select-none backdrop-blur-sm"
                        style={{ borderColor: checked ? "rgba(28,122,28,0.35)" : "rgba(203,213,225,0.5)", background: checked ? "rgba(240,250,240,0.7)" : "rgba(255,255,255,0.6)" }}
                      >
                        <motion.div
                          animate={{ background: checked ? "#1e7d1e" : "rgba(255,255,255,0.9)", scale: checked ? [1, 1.2, 1] : 1 }}
                          transition={{ duration: 0.18 }}
                          className="w-5 h-5 rounded-md border-2 flex items-center justify-center flex-shrink-0"
                          style={{ borderColor: checked ? "#1e7d1e" : "#cbd5e1" }}
                        >
                          <AnimatePresence>
                            {checked && (
                              <motion.div key="c" initial={{ scale: 0, opacity: 0 }} animate={{ scale: 1, opacity: 1 }} exit={{ scale: 0 }} transition={{ type: "spring", stiffness: 500, damping: 25 }}>
                                <Icon.Check size={11} className="text-white" style={{ strokeWidth: 3 }} />
                              </motion.div>
                            )}
                          </AnimatePresence>
                        </motion.div>
                        <span className="text-sm font-medium text-slate-700">{o}</span>
                      </motion.div>
                    );
                  })}
                </div>
              )}
            </motion.div>
          ))}
        </motion.div>
      </Card>

      <Tip text="Double-check details to avoid delays. You'll get a token number after submitting." />

      <div className="flex gap-2 mt-4">
        <Btn variant="primary" size="lg" className="flex-1" onClick={handleSubmit}>
          Get Token <Icon.ChevronR size={15} />
        </Btn>
        <Btn variant="secondary" size="lg" onClick={() => nav("client-dash")}>
          Cancel
        </Btn>
      </div>
    </motion.div>
  );
};

