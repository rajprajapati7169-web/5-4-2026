          </Field>

          <Field label="Label">
            <Input value={title} onChange={e => setTitle(e.target.value)} placeholder="e.g. Full Name" />
          </Field>

          <AnimatePresence mode="popLayout">
            {type === "input" && (
              <motion.div key="ph" initial={{ opacity: 0, height: 0 }} animate={{ opacity: 1, height: "auto" }} exit={{ opacity: 0, height: 0 }} transition={{ duration: 0.2 }}>
                <Field label="Placeholder text">
                  <Input value={ph} onChange={e => setPh(e.target.value)} placeholder="e.g. Enter your name" />
                </Field>
              </motion.div>
            )}
            {(type === "checkbox" || type === "menu") && (
              <motion.div key="opts" initial={{ opacity: 0, height: 0 }} animate={{ opacity: 1, height: "auto" }} exit={{ opacity: 0, height: 0 }} transition={{ duration: 0.2 }}>
                <Field label="Options (comma separated)">
                  <Input value={opts} onChange={e => setOpts(e.target.value)} placeholder="Option A, Option B, Option C" />
                </Field>
              </motion.div>
            )}
          </AnimatePresence>

          <Btn variant="primary" size="xl" onClick={handleAdd} disabled={!title.trim()}>
            <Icon.Plus size={15} /> Add Field
          </Btn>
          <Tip text="Keep forms short for faster entries. Less is more." />
        </Card>

        {/* Preview panel */}
        <div>
          <SectionHead title="Form Preview" count={fields.length} />
          {fields.length === 0
            ? <Empty icon={Icon.Clipboard} title="No fields yet" subtitle="Add your first field from the builder panel" />
            : (
              <>
                <AnimatePresence>
                  {fields.map(f => {
                    const TypeIcon = typeIcons[f.type];
                    return (
                      <motion.div
                        key={f.id}
                        className="field-chip"
                        variants={anim.cardItem}
                        initial="initial"
                        animate="animate"
                        exit={anim.cardItem.exit}
                        whileHover={{ x: 3, transition: { duration: 0.15 } }}
                        layout
                      >
                        <div className={`w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0 ${f.type === "input" ? "bg-blue-100 text-blue-600" : f.type === "checkbox" ? "bg-jade-100 text-jade-600" : "bg-amber-100 text-amber-600"}`}>
                          <TypeIcon size={15} />
                        </div>
                        <div className="flex-1 min-w-0">
                          <div className="text-sm font-bold text-slate-800">{f.title}</div>
                          {f.options?.length > 0 && (
                            <div className="text-xs text-slate-400 truncate mt-0.5">{f.options.join(" · ")}</div>
                          )}
                        </div>
                        <Badge color={typeColors[f.type]}>{f.type}</Badge>
                        <Btn variant="danger" size="xs" onClick={() => removeField(f.id)}>
                          <Icon.X size={11} />
                        </Btn>
                      </motion.div>
                    );
                  })}
                </AnimatePresence>
                <div className="mt-5 flex gap-2">
                  <Btn variant="primary" size="md" onClick={() => showToast("Form published! QR code ready.", "success")}>
                    <Icon.QR size={15} /> Generate QR
                  </Btn>
                  <Btn variant="outline" size="md" onClick={() => showToast("Form published!", "success")}>
                    <Icon.Bolt size={14} /> Publish
                  </Btn>
                </div>
              </>
            )
          }
        </div>
      </div>
    </motion.div>
  );
};

