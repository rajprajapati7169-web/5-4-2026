  const completed = customers.filter(c => c.status === "Completed");

  const handleNext = () => { nextCustomer(); showToast("Customer called successfully ✓", "success"); };
  const handleSkip = () => { skipCustomer(); showToast("Customer moved to next position", "info"); };

  return (
    <motion.div {...anim.page}>
      <ToastStack toasts={toasts} />

      {!isDesktop && (
        <div className="mb-5">
          <h1 className="text-2xl font-black text-slate-800 tracking-tight">Live Queue</h1>
