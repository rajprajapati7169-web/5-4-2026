const AppProvider = ({ children }) => {
  const [user,      setUser]      = useState(null);
  const [page,      setPage]      = useState("auth");
  const [customers, setCustomers] = useState(MOCK_CUSTOMERS);
  const [coords,    setCoords]    = useState(MOCK_COORDS);
  const [fields,    setFields]    = useState([]);

  const nav    = useCallback(p => setPage(p), []);
  const login  = useCallback((email, role) => {
    setUser({ email, role });
    setPage(role === "client" ? "client-dash" : "admin-dash");
  }, []);
  const logout = useCallback(() => { setUser(null); setFields([]); setPage("auth"); }, []);

  const nextCustomer   = useCallback(() => setCustomers(p => {
    const w = p.find(c => c.status === "Waiting");
    return w ? p.map(c => c.id === w.id ? { ...c, status: "Completed" } : c) : p;
  }), []);
  const skipCustomer   = useCallback(() => setCustomers(p => {
    const i = p.findIndex(c => c.status === "Waiting");
    if (i === -1 || i === p.length - 1) return p;
    const u = [...p]; [u[i], u[i + 1]] = [u[i + 1], u[i]]; return u;
  }), []);
  const removeCustomer = useCallback(id => setCustomers(p => p.filter(c => c.id !== id)), []);
  const addCoord       = useCallback(({ email, name, role }) =>
    setCoords(p => [...p, { id: Date.now(), email, name: name || email.split("@")[0], role: role || "Coordinator" }]), []);
  const removeCoord    = useCallback(id => setCoords(p => p.filter(c => c.id !== id)), []);
  const addField       = useCallback(f => setFields(p => [...p, { ...f, id: Date.now() }]), []);
  const removeField    = useCallback(id => setFields(p => p.filter(f => f.id !== id)), []);

  const value = useMemo(() => ({
    user, page, nav, login, logout,
    customers, nextCustomer, skipCustomer, removeCustomer,
    coords, addCoord, removeCoord,
    fields, addField, removeField,
    stats: MOCK_STATS, clientData: MOCK_CLIENT,
  }), [user, page, customers, coords, fields]);

  return <AppCtx.Provider value={value}>{children}</AppCtx.Provider>;
};

