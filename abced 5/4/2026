          <SectionHead title="In Queue" count={waiting.length} />
          {waiting.length === 0
            ? <Empty icon={Icon.Check} title="Queue is empty" subtitle="Customers will appear once they join" />
            : (
              <AnimatePresence>
                {waiting.map((c, i) => (
                  <CustomerCard key={c.id} customer={c} isFirst={i === 0} onRemove={removeCustomer} />
                ))}
              </AnimatePresence>
            )
          }

          {completed.length > 0 && (
            <div className="mt-6">
              <SectionHead title="Completed" count={completed.length} />
