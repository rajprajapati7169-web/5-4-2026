// § PAGE: ADD COORDINATOR
// ═══════════════════════════════════════════════════════════
const AddCoordinator = () => {
  const { coords, addCoord, removeCoord } = useApp();
  const { isDesktop } = useBreakpoint();
  const [email, setEmail] = useState("");
  const [name,  setName]  = useState("");
  const [role,  setRole]  = useState("Doctor");
  const [toasts, showToast] = useToast();

  const handleAdd = () => {
    if (!email.trim()) return;
    addCoord({ email, name, role });
    setEmail(""); setName(""); setRole("Doctor");
    showToast("Coordinator added!", "success");
  };

  return (
    <motion.div {...anim.page}>
      <ToastStack toasts={toasts} />

      {!isDesktop && (
        <div className="mb-5">
          <h1 className="text-2xl font-black text-slate-800 tracking-tight">Team</h1>
          <p className="text-sm text-slate-500 mt-0.5">Manage your queue coordinators.</p>
        </div>
      )}

      <div className={isDesktop ? "grid grid-cols-[340px_1fr] gap-6 items-start" : ""}>
        <Card className={`p-5 ${isDesktop ? "sticky top-4" : "mb-4"}`}>
          <div className="text-xs font-extrabold text-slate-400 uppercase tracking-widest mb-4">Add Member</div>
          <Field label="Full name">
            <Input value={name} onChange={e => setName(e.target.value)} placeholder="Dr. Suresh Kumar" />
          </Field>
          <Field label="Email address">
            <Input type="email" value={email} onChange={e => setEmail(e.target.value)} placeholder="name@hospital.com"
              onKeyDown={e => e.key === "Enter" && handleAdd()} />
          </Field>
          <Field label="Role">
            <Select value={role} onChange={e => setRole(e.target.value)}>
              {["Doctor", "Nurse", "Coordinator", "Receptionist", "Admin"].map(r => (
                <option key={r}>{r}</option>
              ))}
            </Select>
          </Field>
          <Btn variant="primary" size="xl" onClick={handleAdd} disabled={!email.trim()}>
            <Icon.Plus size={15} /> Add to Team
          </Btn>
          <Tip text="Coordinators can call, skip and manage the queue from any device." />
        </Card>

        <div>
          <SectionHead title="Active Team" count={coords.length} />
          {coords.length === 0
            ? <Empty icon={Icon.Users} title="No team members yet" subtitle="Add coordinators to help manage the queue" />
            : (
              <AnimatePresence>
                {coords.map(c => (
                  <motion.div
                    key={c.id}
                    className="customer-card"
                    variants={anim.slideRight}
                    initial="initial"
                    animate="animate"
                    exit={anim.slideRight.exit}
                    layout
                    whileHover={{ y: -2 }}
                  >
                    <Avatar name={c.name} size="md" />
                    <div className="flex-1 min-w-0">
                      <div className="text-sm font-bold text-slate-800">{c.name}</div>
                      <div className="text-xs text-slate-400 truncate">{c.email}</div>
                    </div>
                    <div className="flex items-center gap-2">
                      <Badge color="jade">{c.role}</Badge>
                      <Btn variant="danger" size="xs" onClick={() => removeCoord(c.id)}>
                        <Icon.X size={11} />
                      </Btn>
                    </div>
                  </motion.div>
                ))}
              </AnimatePresence>
            )
          }
        </div>
      </div>
    </motion.div>
  );
};

