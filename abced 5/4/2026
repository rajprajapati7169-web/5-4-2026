        <div>
          <div className="flex gap-2 mb-5">
            <Btn variant="primary" size="md" onClick={handleNext} disabled={waiting.length === 0}>
              <Icon.Play size={14} /> Call Next
            </Btn>
            <Btn variant="warning" size="md" onClick={handleSkip} disabled={waiting.length < 2}>
              <Icon.Skip size={14} /> Skip
            </Btn>
