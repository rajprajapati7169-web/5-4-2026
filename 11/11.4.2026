  <div class="tech">
    <div class="tt">Technology Stack & APIs</div>
    <div class="badges">
      <span class="tbadge">React / Next.js</span>
      <span class="tbadge">Node.js</span>
      <span class="tbadge">WebSockets (Live updates)</span>
      <span class="tbadge">RESTful API</span>
      <span class="tbadge">AI wait‑time predictor</span>
      <span class="tbadge">QR code engine</span>
    </div>
    <div class="apidesc">
      <strong>🗲 Queue Eliminator API Bagiya</strong> — A modular, real‑time backend that powers digital queues, live position tracking, and smart notifications.
      Built for hospitals, banks, and government offices. Seamless integration with <strong>WebSocket streams</strong> and <strong>secure REST endpoints</strong>.
    </div>
  </div>
</div>

<script>
(function(){
  const cv=document.getElementById('c'),ctx=cv.getContext('2d');
  let W,H,P=[];
  function init(){
    W=cv.width=innerWidth;H=cv.height=innerHeight;P=[];
    for(let i=0;i<180;i++)P.push({x:Math.random()*W,y:Math.random()*H,r:Math.random()*3+1.2,a:Math.random()*.4+.2,vx:(Math.random()-.5)*.25,vy:(Math.random()-.5)*.25});
  }
  function draw(){
    ctx.clearRect(0,0,W,H);
    for(let p of P){
      ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fillStyle=`rgba(80,110,70,${p.a*.7})`;ctx.fill();
      ctx.shadowBlur=6;ctx.shadowColor='rgba(100,130,80,.5)';ctx.fill();ctx.shadowBlur=0;
      p.x+=p.vx;p.y+=p.vy;
      if(p.x<-10)p.x=W+10;if(p.x>W+10)p.x=-10;
      if(p.y<-10)p.y=H+10;if(p.y>H+10)p.y=-10;
    }
    requestAnimationFrame(draw);
  }
  addEventListener('resize',init);
  init();draw();
})();
</script>
</body>
</html>
