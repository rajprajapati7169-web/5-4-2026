<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Queue Eliminator · Premium Glass UI</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:opsz,wght@14..32,300..700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-user-select:none;user-select:none;-webkit-tap-highlight-color:transparent}
body{background:radial-gradient(circle at 10% 20%,rgba(31,58,30,.08) 0%,transparent 70%),linear-gradient(135deg,#E8EDE6,#F0F4EF);font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;color:#1a2a1a;line-height:1.5;min-height:100vh}
#c{position:fixed;inset:0;z-index:0;pointer-events:none}
.wrap{max-width:1280px;margin:0 auto;padding:3rem 2rem 5rem;position:relative;z-index:2}
.badge,.title,.sub,.line,.grid,.tech{opacity:0;animation:up .65s cubic-bezier(.2,.9,.4,1.1) forwards}
.badge{animation-delay:.05s}.title{animation-delay:.1s}.sub{animation-delay:.15s}.line{animation-delay:.2s}.grid{animation-delay:.25s}.tech{animation-delay:.4s}
@keyframes up{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.badge{font-size:.7rem;font-weight:700;letter-spacing:.25em;text-transform:uppercase;color:#1F3A1E;margin-bottom:.75rem}
.title{font-family:'Playfair Display',Georgia,serif;font-size:clamp(2.2rem,5vw,3.4rem);font-weight:700;letter-spacing:-.02em;color:#0f2e1c;margin-bottom:.6rem}
.sub{font-size:clamp(.9rem,1.5vw,1.05rem);color:#2c4a2c;max-width:580px;margin-bottom:1.2rem;font-weight:500}
.line{width:60px;height:3px;background:#1F3A1E;border-radius:4px;margin-bottom:2.8rem}
.grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;margin-top:1rem}
.card{position:relative;background:rgba(255,255,255,.13);backdrop-filter:blur(11px) saturate(140%);-webkit-backdrop-filter:blur(11px) saturate(140%);border-radius:32px;box-shadow:0 12px 28px rgba(0,0,0,.06),inset 0 1px 0 rgba(255,255,255,.2);transition:all .35s cubic-bezier(.2,.9,.4,1.1);overflow:hidden;border:1px solid rgba(255,255,255,.35)}
.card:hover{transform:translateY(-8px) scale(1.01);background:rgba(255,255,255,.2);border-color:rgba(255,255,255,.6);box-shadow:0 24px 36px -12px rgba(31,58,30,.3),0 12px 28px rgba(0,0,0,.12),inset 0 1px 0 rgba(255,255,255,.4)}
.card::before{content:'';position:absolute;inset:0;border-radius:32px;padding:1px;background:radial-gradient(circle at 30% 20%,rgba(255,255,240,.2),transparent 80%);mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);-webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);-webkit-mask-composite:xor;mask-composite:exclude;pointer-events:none;opacity:.6;transition:opacity .3s ease}
.card:hover::before{opacity:.9}
.body{padding:1.8rem 1.5rem}
.name{font-size:1.4rem;font-weight:700;letter-spacing:-.3px;margin-bottom:.4rem;color:#0a2a0a}
.role{font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#1c4a1c}
.div{width:40px;height:2px;background:rgba(31,58,30,.55);margin:.75rem 0 .9rem;border-radius:4px}
.desc{font-size:.82rem;line-height:1.55;color:rgba(0,0,0,.82);font-weight:500;margin-bottom:1.5rem}
.links{display:flex;flex-wrap:wrap;gap:.7rem}
.links:empty{display:none}
a.lnk{display:inline-flex;align-items:center;gap:.35rem;padding:.4rem 1rem;background:rgba(255,255,255,.45);backdrop-filter:blur(2px);border-radius:40px;font-size:.7rem;font-weight:600;text-decoration:none;color:#0f2e1c;transition:all .25s cubic-bezier(.2,.9,.4,1.1);border:1px solid rgba(31,58,30,.45)}
a.lnk svg{width:11px;height:11px;stroke:#1F3A1E;stroke-width:2;fill:none;transition:transform .2s ease}
a.lnk:hover{background:rgba(31,58,30,.2);border-color:#1F3A1E;transform:translateY(-2px) scale(1.02);box-shadow:0 4px 8px rgba(0,0,0,.05)}
a.lnk:hover svg{transform:scale(1.05)}
.tech{margin-top:4.5rem;padding:2rem;background:rgba(255,255,255,.14);backdrop-filter:blur(11px) saturate(140%);border-radius:48px;box-shadow:0 10px 24px rgba(0,0,0,.05);text-align:center;transition:all .35s cubic-bezier(.2,.9,.4,1.1);border:1px solid rgba(255,255,255,.35)}
.tech:hover{background:rgba(255,255,255,.22);transform:translateY(-3px);box-shadow:0 18px 30px -12px rgba(31,58,30,.2)}
.tt{font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:700;color:#0a2a0a;margin-bottom:1rem}
.badges{display:flex;flex-wrap:wrap;justify-content:center;gap:1rem;margin:1.2rem 0 1rem}
.tbadge{background:rgba(255,255,255,.35);backdrop-filter:blur(2px);border-radius:100px;padding:.45rem 1.3rem;font-size:.75rem;font-weight:600;color:#1F3A1E;border:1px solid rgba(255,255,255,.45);transition:all .25s cubic-bezier(.2,.9,.4,1.1)}
.tbadge:hover{background:rgba(31,58,30,.15);border-color:#1F3A1E;transform:translateY(-2px) scale(1.02)}
.apidesc{font-size:.85rem;color:rgba(0,0,0,.8);font-weight:500;max-width:700px;margin:1.2rem auto 0;line-height:1.55}
.apidesc strong{color:#0f2e1c;font-weight:700}
@media(max-width:1000px){.grid{gap:1.5rem}}
@media(max-width:850px){.grid{grid-template-columns:repeat(2,1fr);gap:1.8rem}}
@media(max-width:550px){.wrap{padding:2rem 1.2rem 4rem}.body{padding:1.5rem 1.2rem 1.4rem}.name{font-size:1.25rem}}
@media(max-width:480px){.grid{grid-template-columns:1fr;max-width:380px;margin-left:auto;margin-right:auto}}
</style>
</head>
<body>
<canvas id="c"></canvas>
<div class="wrap">
  <div class="badge">OUR PEOPLE</div>
  <h1 class="title">Meet the team</h1>
  <p class="sub">The minds behind Queue Eliminator</p>
