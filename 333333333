      </Card>

      <Tip text="Double-check details to avoid delays. You'll get a token number after submitting." />

      <div style={{ display: "flex", gap: "0.5rem", marginTop: "1rem" }}>
        <Btn variant="primary" size="lg" style={{ flex: 1 }} onClick={handleSubmit}>
          Get Token <Icon.ChevronR size={15} />
