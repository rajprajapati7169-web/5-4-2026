                        }}
                      >
                        <motion.div
                          animate={{ background: checked ? "#1e7d1e" : "rgba(255,255,255,0.9)" }}
                          transition={{ duration: 0.18 }}
                          style={{ width: 20, height: 20, borderRadius: "0.375rem", border: `2px solid ${checked ? "#1e7d1e" : "#cbd5e1"}`, display: "flex", alignItems: "center", justifyContent: "center", flexShrink: 0 }}
