            transition={{ delay: 0.2, type: "spring", stiffness: 300 }}
            style={{ fontSize: "1.5rem", fontWeight: 900, color: "#1e7d1e", fontFamily: "monospace" }}
          >{clientData.token}</motion.span>
        </Card>
        <Card style={{ padding: "1rem" }}>
          <div style={{ fontSize: "0.75rem", fontWeight: 800, color: "#94a3b8", textTransform: "uppercase", letterSpacing: "0.1em", marginBottom: "0.5rem" }}>Est. Wait</div>
          <div style={{ display: "flex", alignItems: "flex-end", gap: "0.25rem" }}>
            <span style={{ fontSize: "2.25rem", fontWeight: 900, color: "#d97706" }}>{clientData.estimatedWait}</span>
            <span style={{ fontSize: "0.875rem", color: "#94a3b8", marginBottom: "0.375rem", fontWeight: 500 }}>min</span>
          </div>
        </Card>
      </div>

      <Card style={{ padding: "1rem", border: "1px solid rgba(184,236,184,0.6)", background: "rgba(240,250,240,0.4)" }}>
        <div style={{ display: "flex", alignItems: "center", gap: "0.5rem", color: "#175c17", fontWeight: 700, fontSize: "0.875rem", marginBottom: "0.5rem" }}>
          <Icon.Bell size={15} /> Wait Smart. Move only when it's your turn.
        </div>
        <p style={{ fontSize: "0.75rem", color: "#64748b", lineHeight: 1.625 }}>We'll update your position in real-time. Stay nearby once you're in the top 3.</p>
        <Tip text="Stay within range once you're close ⚡" />
      </Card>
    </motion.div>
  );
};

// ═══════════════════════════════════════════════════════════
// § SHELL — routing + layout
// FIX: PAGES moved inside Shell as a function to avoid stale JSX element issues
// ═══════════════════════════════════════════════════════════
const PAGE_TITLES = {
  "admin-dash":      "Dashboard",
  "track-customer":  "Live Queue",
  "generate-form":   "Form Builder",
  "add-coordinator": "Team",
  "client-dash":     "My Spot",
  "client-form":     "Join Queue",
};

const Shell = () => {
  const { user, page } = useApp();
  const { isDesktop } = useBreakpoint();

  // FIX: Pages defined as a render function lookup, not pre-instantiated JSX objects
  const renderPage = () => {
    switch (page) {
      case "admin-dash":      return <AdminDash />;
      case "track-customer":  return <TrackCustomer />;
      case "generate-form":   return <GenerateForm />;
      case "add-coordinator": return <AddCoordinator />;
      case "client-dash":     return <ClientDash />;
      case "client-form":     return <ClientForm />;
      default:                return <AdminDash />;
    }
  };

  if (!user) return <AuthPage />;

  const isAdmin = user.role !== "client";
  const tabs    = isAdmin ? ADMIN_NAV : CLIENT_NAV;

  if (isAdmin && isDesktop) {
    return (
      <div className="desktop-shell">
        <BgCanvas />
        <Sidebar />
        <div className="desktop-main">
          <div className="desktop-topbar">
            <h2 style={{ fontSize: "1.25rem", fontWeight: 800, color: "#1e293b", letterSpacing: "-0.025em" }}>{PAGE_TITLES[page]}</h2>
            <div style={{ display: "flex", alignItems: "center", gap: "0.75rem" }}>
              <div style={{ display: "flex", alignItems: "center", gap: "0.5rem", background: "rgba(255,255,255,0.7)", border: "1px solid rgba(255,255,255,0.8)", borderRadius: "9999px", padding: "0.5rem 1rem", boxShadow: "0 1px 2px rgba(0,0,0,0.05)" }}>
                <div style={{ width: 8, height: 8, borderRadius: "50%", background: "#28a428", boxShadow: "0 0 6px rgba(40,164,40,0.6)" }} />
                <span style={{ fontSize: "0.75rem", fontWeight: 600, color: "#475569" }}>{user.email}</span>
              </div>
            </div>
          </div>
          <div className="desktop-content">
            <AnimatePresence mode="wait">
              <motion.div key={page} initial={anim.page.initial} animate={anim.page.animate} exit={anim.page.exit}>
                {renderPage()}
              </motion.div>
            </AnimatePresence>
          </div>
        </div>
      </div>
    );
  }

  return (
    <div className="mobile-shell">
      <BgCanvas />
      <Topbar title={PAGE_TITLES[page]} />
      <div className="mobile-content">
        <AnimatePresence mode="wait">
          <motion.div key={page} initial={anim.page.initial} animate={anim.page.animate} exit={anim.page.exit}>
            {renderPage()}
          </motion.div>
        </AnimatePresence>
      </div>
      <BottomNav tabs={tabs} />
    </div>
  );
};

