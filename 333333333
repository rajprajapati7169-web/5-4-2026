                            {checked && (
                              <motion.div key="c" initial={{ scale: 0, opacity: 0 }} animate={{ scale: 1, opacity: 1 }} exit={{ scale: 0 }} transition={{ type: "spring", stiffness: 500, damping: 25 }}>
                                <Icon.Check size={11} style={{ color: "#fff", strokeWidth: 3 }} />
