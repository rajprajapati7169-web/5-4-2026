  const waiting   = customers.filter(c => c.status === "Waiting");
  const completed = customers.filter(c => c.status === "Completed");

  const handleNext = () => { nextCustomer(); showToast("Customer called successfully ✓", "success"); };
  const handleSkip = () => { skipCustomer(); showToast("Customer moved to next position", "info"); };

  return (
    <motion.div initial={anim.page.initial} animate={anim.page.animate} exit={anim.page.exit}>
      <ToastStack toasts={toasts} />

      {!isDesktop && (
        <div style={{ marginBottom: "1.25rem" }}>
          <h1 style={{ fontSize: "1.5rem", fontWeight: 900, color: "#1e293b", letterSpacing: "-0.025em" }}>Live Queue</h1>
          <p style={{ fontSize: "0.875rem", color: "#64748b", marginTop: "0.125rem" }}>Serve faster. Stay organised.</p>
        </div>
      )}

      <div style={isDesktop ? { display: "grid", gridTemplateColumns: "1fr 280px", gap: "1.5rem", alignItems: "start" } : {}}>
        <div>
          <div style={{ display: "flex", gap: "0.5rem", marginBottom: "1.25rem" }}>
            <Btn variant="primary" size="md" onClick={handleNext} disabled={waiting.length === 0}>
              <Icon.Play size={14} /> Call Next
            </Btn>
            <Btn variant="warning" size="md" onClick={handleSkip} disabled={waiting.length < 2}>
              <Icon.Skip size={14} /> Skip
            </Btn>
          </div>

          <SectionHead title="In Queue" count={waiting.length} />
          {waiting.length === 0
            ? <Empty icon={Icon.Check} title="Queue is empty" subtitle="Customers will appear once they join" />
            : (
              <AnimatePresence>
                {waiting.map((c, i) => (
                  <CustomerCard key={c.id} customer={c} isFirst={i === 0} onRemove={removeCustomer} />
                ))}
              </AnimatePresence>
            )
          }

          {completed.length > 0 && (
            <div style={{ marginTop: "1.5rem" }}>
              <SectionHead title="Completed" count={completed.length} />
              <AnimatePresence>
                {completed.map(c => (
                  <motion.div key={c.id} className="customer-card" style={{ opacity: 0.7 }} variants={anim.cardItem} initial="initial" animate="animate">
                    <div style={{ width: 44, height: 44, borderRadius: "1rem", background: "#dcf5dc", color: "#175c17", display: "flex", alignItems: "center", justifyContent: "center", fontSize: "0.875rem", fontWeight: 700, flexShrink: 0 }}>
                      {c.name.split(" ").map(w => w[0]).join("").slice(0, 2)}
                    </div>
                    <div style={{ flex: 1, minWidth: 0 }}>
                      <div style={{ fontSize: "0.875rem", fontWeight: 600, color: "#334155", overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>{c.name}</div>
                      <div style={{ fontSize: "0.75rem", color: "#94a3b8", fontFamily: "monospace" }}>{c.token}</div>
                    </div>
                    <Badge color="jade" dot>Served</Badge>
                  </motion.div>
                ))}
              </AnimatePresence>
            </div>
          )}
        </div>

        {isDesktop && (
          <div style={{ display: "flex", flexDirection: "column", gap: "0.75rem" }}>
            <Card style={{ padding: "1rem", position: "sticky", top: "1rem" }}>
              <div style={{ fontSize: "0.75rem", fontWeight: 800, color: "#94a3b8", textTransform: "uppercase", letterSpacing: "0.1em", marginBottom: "1rem" }}>Live Stats</div>
              <div style={{ display: "grid", gridTemplateColumns: "repeat(2, 1fr)", gap: "0.75rem" }}>
                {[
                  { val: waiting.length,   label: "Waiting",   color: "#1e7d1e",  bg: "#f0faf0" },
                  { val: completed.length, label: "Served",    color: "#475569",  bg: "#f8fafc" },
                ].map(s => (
                  <div key={s.label} style={{ background: s.bg, borderRadius: "0.75rem", padding: "0.75rem", textAlign: "center", border: "1px solid rgba(255,255,255,0.6)" }}>
                    <motion.div key={s.val} initial={{ scale: 1.3, opacity: 0 }} animate={{ scale: 1, opacity: 1 }} style={{ fontSize: "1.875rem", fontWeight: 900, color: s.color }}>{s.val}</motion.div>
                    <div style={{ fontSize: "0.75rem", color: "#94a3b8", fontWeight: 700, marginTop: "0.25rem", textTransform: "uppercase", letterSpacing: "0.05em" }}>{s.label}</div>
                  </div>
                ))}
              </div>
              <div style={{ marginTop: "1rem", paddingTop: "1rem", borderTop: "1px solid #f1f5f9" }}>
                <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", fontSize: "0.75rem", color: "#64748b", marginBottom: "0.375rem" }}>
                  <span>Completion rate</span>
                  <span style={{ fontWeight: 700, color: "#1e7d1e" }}>{waiting.length + completed.length > 0 ? Math.round(completed.length / (waiting.length + completed.length) * 100) : 0}%</span>
                </div>
                <div style={{ height: 8, background: "#f1f5f9", borderRadius: "9999px", overflow: "hidden" }}>
                  <motion.div
                    style={{ height: "100%", background: "linear-gradient(135deg, #28a428, #175c17)", borderRadius: "9999px" }}
                    initial={{ width: 0 }}
                    animate={{ width: `${waiting.length + completed.length > 0 ? Math.round(completed.length / (waiting.length + completed.length) * 100) : 0}%` }}
                    transition={{ duration: 0.8, ease: "easeOut" }}
                  />
                </div>
              </div>
            </Card>
            <Tip text="Follow the order or make quick decisions when needed." />
          </div>
        )}
      </div>
    </motion.div>
  );
};

